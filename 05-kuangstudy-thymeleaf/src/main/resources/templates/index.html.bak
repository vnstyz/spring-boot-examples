п»ҝ<!DOCTYPE html>
<html lang="zh-CN" xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>е‘ҳе·ҘеҲ—иЎЁ</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body class="bg-body-tertiary">
<div class="container py-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white d-flex flex-wrap justify-content-between align-items-center gap-2">
            <div>
                <h5 class="mb-1">е‘ҳе·Ҙз®ЎзҗҶ</h5>
                <small class="text-secondary">еҲҶйЎөжҹҘиҜў + жү№йҮҸж“ҚдҪң</small>
            </div>
            <div class="d-flex gap-2">
                <!-- [MOD-PAGINATION] еҲҶйЎөеӨ§е°ҸеҲҮжҚў -->
                <form class="d-flex" method="get" th:action="@{/}">
                    <input type="hidden" name="pageNo" value="1">
                    <select name="pageSize" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="5" th:selected="${page.size == 5}">5жқЎ/йЎө</option>
                        <option value="10" th:selected="${page.size == 10}">10жқЎ/йЎө</option>
                        <option value="20" th:selected="${page.size == 20}">20жқЎ/йЎө</option>
                        <option value="50" th:selected="${page.size == 50}">50жқЎ/йЎө</option>
                    </select>
                </form>
                <a th:href="@{/employee/add}" class="btn btn-sm btn-success">
                    <i class="bi bi-plus-lg"></i> ж–°еўһе‘ҳе·Ҙ
                </a>
            </div>
        </div>

        <div class="card-body">
            <!-- [MOD-BATCH] жү№йҮҸеҲ йҷӨзӣҙжҺҘйҖҡиҝҮ checkbox name=ids жҸҗдәӨ -->
            <form id="batchDeleteForm" method="post"
                  th:action="@{/employee/batchDelete(pageNo=${page.current},pageSize=${page.size})}">
                <div class="table-responsive">
                    <table class="table table-hover align-middle text-center mb-0">
                        <thead>
                        <tr>
                            <th style="width: 40px;"><input class="form-check-input" type="checkbox" id="selectAll"></th>
                            <th style="width: 90px;">еәҸеҸ·</th>
                            <th>е§“еҗҚ</th>
                            <th style="width: 90px;">жҖ§еҲ«</th>
                            <th>йӮ®з®ұ</th>
                            <th style="width: 110px;">йғЁй—Ё</th>
                            <th style="width: 150px;">з”ҹж—Ҙ</th>
                            <th style="width: 210px;">ж“ҚдҪң</th>
                        </tr>
                        </thead>
                        <tbody>
                        <tr th:if="${#lists.isEmpty(employees)}">
                            <td colspan="8" class="text-center text-secondary py-4">жҡӮж— ж•°жҚ®</td>
                        </tr>

                        <tr th:each="employee, stat : ${employees}">
                            <td>
                                <input class="form-check-input employee-checkbox" type="checkbox" name="ids"
                                       th:value="${employee.id}">
                            </td>
                            <td th:text="${(page.current - 1) * page.size + stat.index + 1}">1</td>
                            <td th:text="${employee.lastName}">еј дёү</td>
                            <td>
                                <span class="badge text-bg-light border"
                                      th:text="${employee.gender == 1 ? 'з”·' : 'еҘі'}">з”·</span>
                            </td>
                            <td th:text="${employee.email}">demo@example.com</td>
                            <td th:text="${employee.department}">101</td>
                            <td th:text="${employee.birth}">2000-01-01</td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a th:href="@{/employee/edit/{id}(id=${employee.id})}" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil-square"></i> зј–иҫ‘
                                    </a>
                                    <button type="button" class="btn btn-sm btn-outline-danger"
                                            th:data-id="${employee.id}"
                                            th:data-page-no="${page.current}"
                                            th:data-page-size="${page.size}"
                                            th:data-name="${employee.lastName}"
                                            onclick="confirmDelete(this)">
                                        <i class="bi bi-trash"></i> еҲ йҷӨ
                                    </button>
                                </div>
                            </td>
                        </tr>
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-3">
                    <div class="d-flex gap-2 align-items-center">
                        <button id="batchDeleteBtn" type="submit" class="btn btn-sm btn-danger" disabled
                                onclick="return confirmBatchDelete();">
                            <i class="bi bi-trash"></i> жү№йҮҸеҲ йҷӨ
                        </button>
                        <small class="text-secondary" th:text="'е…ұ ' + ${page.total} + ' жқЎи®°еҪ•'">е…ұ 0 жқЎи®°еҪ•</small>
                    </div>

                    <!-- [MOD-PAGINATION] еҠЁжҖҒеҲҶйЎөеҜјиҲӘ -->
                    <nav th:if="${page.pages > 0}">
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item" th:classappend="${page.current == 1} ? 'disabled'">
                                <a class="page-link" th:href="@{/(pageNo=1,pageSize=${page.size})}">йҰ–йЎө</a>
                            </li>
                            <li class="page-item" th:classappend="${page.current == 1} ? 'disabled'">
                                <a class="page-link" th:href="@{/(pageNo=${page.current - 1},pageSize=${page.size})}">дёҠдёҖйЎө</a>
                            </li>

                            <li class="page-item"
                                th:classappend="${pageNumbers[0] > 1} ? '' : 'd-none'">
                                <a class="page-link" th:href="@{/(pageNo=1,pageSize=${page.size})}">1</a>
                            </li>
                            <li class="page-item disabled"
                                th:classappend="${pageNumbers[0] > 2} ? '' : 'd-none'">
                                <span class="page-link">...</span>
                            </li>

                            <li class="page-item" th:each="n : ${pageNumbers}" th:classappend="${n == page.current} ? 'active'">
                                <a class="page-link" th:text="${n}" th:href="@{/(pageNo=${n},pageSize=${page.size})}">1</a>
                            </li>

                            <li class="page-item disabled"
                                th:classappend="${pageNumbers[pageNumbers.size() - 1] < page.pages - 1} ? '' : 'd-none'">
                                <span class="page-link">...</span>
                            </li>
                            <li class="page-item"
                                th:classappend="${pageNumbers[pageNumbers.size() - 1] < page.pages} ? '' : 'd-none'">
                                <a class="page-link" th:href="@{/(pageNo=${page.pages},pageSize=${page.size})}">е°ҫйЎө</a>
                            </li>

                            <li class="page-item" th:classappend="${page.current == page.pages} ? 'disabled'">
                                <a class="page-link" th:href="@{/(pageNo=${page.current + 1},pageSize=${page.size})}">дёӢдёҖйЎө</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    const selectAll = document.getElementById('selectAll');
    const rowChecks = document.querySelectorAll('.employee-checkbox');
    const batchDeleteBtn = document.getElementById('batchDeleteBtn');

    // [MOD-ROBUST] йҒҝе…ҚиЎЁеҚ•еөҢеҘ—пјҢеҚ•еҲ йҖҡиҝҮ JS еҠЁжҖҒжҸҗдәӨ POSTгҖӮ
    function confirmDelete(button) {
        const id = button.dataset.id;
        const pageNo = button.dataset.pageNo;
        const pageSize = button.dataset.pageSize;
        const name = button.dataset.name;
        if (!confirm(`зЎ®и®ӨеҲ йҷӨе‘ҳе·Ҙ ${name} еҗ—пјҹ`)) {
            return;
        }

        const form = document.createElement('form');
        form.method = 'post';
        form.action = `/employee/delete/${id}?pageNo=${pageNo}&pageSize=${pageSize}`;
        document.body.appendChild(form);
        form.submit();
    }

    function refreshBatchButton() {
        const checkedCount = document.querySelectorAll('.employee-checkbox:checked').length;
        batchDeleteBtn.disabled = checkedCount === 0;
    }

    function confirmBatchDelete() {
        const checkedCount = document.querySelectorAll('.employee-checkbox:checked').length;
        if (checkedCount === 0) {
            return false;
        }
        return confirm(`зЎ®и®Өжү№йҮҸеҲ йҷӨйҖүдёӯзҡ„ ${checkedCount} жқЎи®°еҪ•еҗ—пјҹ`);
    }

    selectAll?.addEventListener('change', function () {
        rowChecks.forEach(cb => cb.checked = this.checked);
        refreshBatchButton();
    });

    rowChecks.forEach(cb => {
        cb.addEventListener('change', function () {
            const allChecked = Array.from(rowChecks).every(item => item.checked);
            if (selectAll) {
                selectAll.checked = allChecked;
            }
            refreshBatchButton();
        });
    });
</script>
</body>
</html>
